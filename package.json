{
  "name": "minecraft-custom-launcher",
  "version": "1.0.0",
  "description": "Custom Minecraft Launcher with auto-update for Forge servers",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:mac": "electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.yourserver.launcher",
    "productName": "MyServer Launcher",
    "icon": "src/assets/icon.ico",
    "win": {
      "target": ["nsis"],
      "icon": "src/assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "src/assets/icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "src/assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": []
  },
  "keywords": ["minecraft", "launcher", "forge"],
  "author": "YourName",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.2.0",
    "node-stream-zip": "^1.15.0"
  }
}
